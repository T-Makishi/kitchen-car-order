# 初回管理者設定（本番では32文字以上のランダム値に変更）
ADMIN_SETUP_TOKEN=replace-with-a-random-setup-token

# 公開URLと店舗通知先（店舗設定が空の場合の予備値）
APP_URL=http://localhost:3000
ORDER_NOTIFICATION_EMAIL=makishi0520@gmail.com

# メール: preview（保存のみ）または api（HTTPメールサービス経由）
EMAIL_MODE=preview
EMAIL_API_URL=
EMAIL_API_TOKEN=

# SMTP互換設定（Workerでは直接接続せず、メールAPI側の設定に使用）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=まちの小さなキッチンカー <orders@example.jp>
